{
  "name": "lerms",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "test:contracts": "rm -rf /tmp/lerms-contract-tests && tsc --target ES2022 --module ES2022 --moduleResolution Bundler --outDir /tmp/lerms-contract-tests --noEmit false src/contracts/first-vertical.ts src/terrain/hill-of-hills.ts tests/first-vertical-contracts.ts tests/hill-of-hills-terrain.ts && node /tmp/lerms-contract-tests/tests/first-vertical-contracts.js && node /tmp/lerms-contract-tests/tests/hill-of-hills-terrain.js",
    "test:composer": "node --experimental-strip-types tests/first-vertical-composer-contracts.ts",
    "test:source-truth-upgrade": "node --experimental-strip-types tests/first-vertical-source-truth-upgrade-contracts.ts",
    "test:composer-witness": "node tests/first-vertical-composer-witness-contracts.mjs",
    "test:composer-visual": "node tests/first-vertical-composer-visual-witness-contracts.mjs",
    "test:body-candidates": "node tests/red-lerm-body-candidate-witness-contracts.mjs",
    "test:goin": "node tests/goin-glove-wealth-witness-contracts.mjs",
    "test:goin-ecology-merge": "node --experimental-strip-types tests/goin-ecology-merge-witness-contracts.ts",
    "test:goin-ecology-smoke-offer": "node --experimental-strip-types tests/goin-ecology-smoke-offer-contracts.ts",
    "test:glove-wealth-custody": "node --experimental-strip-types tests/glove-wealth-custody-witness-contracts.ts",
    "test:glove-well-browser-smoke": "node --experimental-strip-types tests/glove-well-browser-smoke-state-contracts.ts",
    "test:glove-input-wilor": "node --experimental-strip-types tests/glove-input-wilor-adapter-contracts.ts",
    "test:glove-well-kaminos-live-throw": "node --experimental-strip-types tests/glove-well-kaminos-live-throw-witness-contracts.ts",
    "test:glove-well-live-compare": "node --experimental-strip-types tests/glove-well-live-comparison-witness-contracts.ts",
    "test:glove-well-live-throw": "node --experimental-strip-types tests/glove-well-live-throw-composition-witness-contracts.ts",
    "test:glove-well-preview-bench-payload": "node --experimental-strip-types tests/glove-well-preview-bench-payload-contracts.ts",
    "test:glove-well-throw-physics": "node --experimental-strip-types tests/glove-well-throw-physics-witness-contracts.ts",
    "test:glove-well": "node --experimental-strip-types tests/glove-well-command-contracts.ts",
    "test:glove-well-visual": "node tests/glove-well-launch-visual-witness-contracts.mjs",
    "test:successor": "node tests/lerm-horde-successor-witness-contracts.mjs",
    "test:red-lerm": "node --experimental-strip-types tests/red-lerm-body-motion-contracts.mjs && node tests/red-lerm-body-motion-witness-contracts.mjs && node tests/red-lerm-visual-witness-contracts.mjs",
    "witness:goin": "node --experimental-strip-types src/goin-glove-wealth-witness.ts",
    "witness:goin-ecology-merge": "node --experimental-strip-types src/goin-ecology-merge-witness.ts",
    "witness:goin-ecology-smoke-offer": "node --experimental-strip-types src/goin-ecology-smoke-offer.ts",
    "witness:glove-wealth-custody": "node --experimental-strip-types src/glove-wealth-custody-witness.ts",
    "witness:glove-well": "node --experimental-strip-types src/glove-well-command.ts",
    "witness:glove-well-kaminos-live-throw": "node --experimental-strip-types src/glove-well-kaminos-live-throw-witness.ts",
    "witness:glove-well-live-compare": "node --experimental-strip-types src/glove-well-live-comparison-witness.ts",
    "witness:glove-well-live-throw": "node --experimental-strip-types src/glove-well-live-throw-composition-witness.ts",
    "witness:glove-well-preview-bench-payload": "node --experimental-strip-types src/glove-well-preview-bench-payload.ts",
    "witness:glove-well-throw-physics": "node --experimental-strip-types src/glove-well-throw-physics-witness.ts",
    "witness:glove-well-visual": "node --experimental-strip-types src/glove-well-launch-visual-witness.ts",
    "witness:lerm-horde-successor": "node --experimental-strip-types src/lerm-horde-successor-witness.ts",
    "witness:composer": "node --experimental-strip-types src/contracts/first-vertical-composer-witness.ts",
    "witness:composer-visual": "node --experimental-strip-types src/contracts/first-vertical-composer-visual-witness.ts",
    "witness:red-lerm-body-candidates": "node --experimental-strip-types src/red-lerm-body-candidate-witness.ts",
    "witness:red-lerm": "node --experimental-strip-types src/red-lerm-body-motion-witness.ts",
    "witness:red-lerm-visual": "node --experimental-strip-types src/red-lerm-visual-witness.ts"
  },
  "dependencies": {
    "vite": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^5.5.0"
  }
}
